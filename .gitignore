# Ignorar pastas de dependências
node_modules/
.pnpm-store/ # Se você estiver usando pnpm e tiver um store global no projeto
pnpm-lock.yaml # Embora geralmente queira o lock file, se estiver tendo problemas com ele
# Ignorar pastas de build e logs
dist/
build/
logs/
.env
.DS_Store # Mac
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Exemplo do .gitignore
# Ignorar a pasta do ambiente virtual Python
venv/
.venv/
env/
# Outras coisas que você pode querer ignorar:
node_modules/
.env
__pycache__/
*.log
backend/.env
.env